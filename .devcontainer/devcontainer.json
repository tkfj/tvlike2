{
    "name": "tvlike2",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspace",
    "customizations": {
        "vscode": {
            "settings": {
                "php.validate.executablePath": "/usr/local/bin/php"
            },
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "onecentlin.laravel-blade",
                "shuhei-kagawa.laravel-jump"
            ]
        }
    },
    "remoteUser": "vscode",
    "postCreateCommand": 
        "composer install &&  ssh -f -N -o StrictHostKeyChecking=no -L 1234:localhost:1234 ${localEnv:USER}${localEnv:USERNAME}@$(ip route | awk '/default/ {print $3}')",
    "containerEnv": {
        "XDEBUG_MODE": "off"
    }
}
